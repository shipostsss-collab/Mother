<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mother's Day Surprise Creator</title>
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --pink-light: #fff0f3;
            --pink-main: #ff85a1;
            --pink-dark: #c9184a;
            --gold: #ffb703;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Poppins', sans-serif;
            background: var(--pink-light);
            color: #444;
            overflow-x: hidden;
        }

        .container { max-width: 600px; margin: 0 auto; padding: 20px; text-align: center; }
        h1, h2 { font-family: 'Great Vibes', cursive; color: var(--pink-dark); }
        
        /* Step Sections */
        .step { display: none; background: white; padding: 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); margin-top: 20px; }
        .step.active { display: block; animation: fadeIn 0.5s ease; }

        input, textarea, select {
            width: 100%; padding: 12px; margin: 10px 0;
            border: 2px solid var(--pink-light); border-radius: 10px; box-sizing: border-box;
        }

        .btn {
            background: var(--pink-main); color: white; border: none; padding: 15px 30px;
            border-radius: 50px; cursor: pointer; font-weight: 600; font-size: 1.1rem;
            transition: 0.3s; margin-top: 20px;
        }
        .btn:hover { background: var(--pink-dark); transform: scale(1.05); }

        /* Balloon Graphics */
        .balloon-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-top: 20px; }
        .balloon {
            width: 60px; height: 80px; background: var(--pink-main);
            border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
            margin: 0 auto; cursor: pointer; position: relative;
            animation: float 3s ease-in-out infinite;
        }
        .balloon::after {
            content: ''; position: absolute; bottom: -10px; left: 50%;
            width: 2px; height: 20px; background: #ccc;
        }

        /* Polaroid Effect */
        .polaroid {
            background: white; padding: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            transform: rotate(-3deg); border-radius: 5px; display: none;
            margin: 20px auto; max-width: 80%;
        }
        .polaroid img { width: 100%; border-radius: 3px; }
        .polaroid p { font-family: 'Great Vibes', cursive; font-size: 1.5rem; margin-top: 10px; }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body>

<div class="container">
    <div id="creator-mode">
        <h1>Surprise Creator</h1>
        
        <div id="step1" class="step active">
            <h2>Basic Info</h2>
            <input type="text" id="momName" placeholder="Enter her name (e.g. Mom, Queen)">
            <select id="occasion">
                <option value="Mother's Day">Mother's Day</option>
                <option value="Birthday">Birthday</option>
            </select>
            <p>Upload Cover Photo:</p>
            <input type="file" id="coverPhoto" accept="image/*">
            <button class="btn" onclick="nextStep(2)">Next: Add Memories</button>
        </div>

        <div id="step2" class="step">
            <h2>Add 12 Balloons</h2>
            <div id="balloonInputs" style="max-height: 400px; overflow-y: auto;">
                </div>
            <button class="btn" onclick="nextStep(3)">Next: Final Message</button>
        </div>

        <div id="step3" class="step">
            <h2>The Grand Finale</h2>
            <p>Upload Final Photo:</p>
            <input type="file" id="finalPhoto" accept="image/*">
            <textarea id="finalLetter" placeholder="Write your final heart-touching message..."></textarea>
            <button class="btn" onclick="generateSurprise()">Generate Surprise Website</button>
        </div>
    </div>

    <div id="surprise-mode" style="display:none;">
        <h1 id="displayTitle">Happy Mother's Day!</h1>
        <div id="coverArea">
            <img id="displayCover" src="" style="width:100%; border-radius: 20px;">
            <button class="btn" onclick="startPopping()">Open My Surprise</button>
        </div>

        <div id="balloonArea" style="display:none;">
            <div class="balloon-grid" id="theBalloons"></div>
            <div id="photoReveal" class="polaroid">
                <img id="revealedImg" src="">
                <p id="revealedText"></p>
            </div>
            <button id="finalBtn" class="btn" style="display:none;" onclick="showFinal()">See Final Message ❤️</button>
        </div>

        <div id="finalArea" style="display:none;">
            <img id="displayFinalImg" src="" style="width:100%; border-radius: 20px;">
            <h2 id="lastLetter"></h2>
            <div style="font-size: 5rem; color: var(--pink-dark);">❤️</div>
        </div>
    </div>
</div>

<script>
    let currentStep = 1;
    let memories = [];
    const balloonContainer = document.getElementById('balloonInputs');

    // Generate 12 slots
    for(let i=1; i<=12; i++) {
        balloonContainer.innerHTML += `
            <div style="border-bottom: 1px solid #eee; padding: 10px;">
                <p>Memory #${i}</p>
                <input type="file" class="memImg" accept="image/*">
                <input type="text" class="memText" placeholder="Short note for this photo">
            </div>
        `;
    }

    function nextStep(s) {
        document.querySelectorAll('.step').forEach(el => el.classList.remove('active'));
        document.getElementById('step' + s).classList.add('active');
    }

    async function generateSurprise() {
        // Collect data
        const name = document.getElementById('momName').value;
        const occasion = document.getElementById('occasion').value;
        const finalMsg = document.getElementById('finalLetter').value;
        
        // Transform images to Base64 for local storage (Simulating a database)
        const coverImg = await toBase64(document.getElementById('coverPhoto').files[0]);
        const finalImg = await toBase64(document.getElementById('finalPhoto').files[0]);

        // Show Surprise Mode
        document.getElementById('creator-mode').style.display = 'none';
        document.getElementById('surprise-mode').style.display = 'block';

        // Setup Display
        document.getElementById('displayTitle').innerText = `Happy ${occasion}, My Queen ${name}!`;
        document.getElementById('displayCover').src = coverImg;
        document.getElementById('displayFinalImg').src = finalImg;
        document.getElementById('lastLetter').innerText = finalMsg;

        // Prepare Balloons
        const imgInputs = document.querySelectorAll('.memImg');
        const textInputs = document.querySelectorAll('.memText');
        for(let i=0; i<12; i++) {
            if(imgInputs[i].files[0]) {
                const b64 = await toBase64(imgInputs[i].files[0]);
                memories.push({ img: b64, txt: textInputs[i].value });
            }
        }
    }

    function startPopping() {
        document.getElementById('coverArea').style.display = 'none';
        document.getElementById('balloonArea').style.display = 'block';
        const grid = document.getElementById('theBalloons');
        
        memories.forEach((m, index) => {
            const b = document.createElement('div');
            b.className = 'balloon';
            b.style.backgroundColor = `hsl(${Math.random() * 360}, 70%, 80%)`;
            b.onclick = () => {
                b.style.visibility = 'hidden';
                popSound();
                revealPhoto(m);
                checkFinish();
            };
            grid.appendChild(b);
        });
    }

    function revealPhoto(m) {
        const pol = document.getElementById('photoReveal');
        pol.style.display = 'block';
        document.getElementById('revealedImg').src = m.img;
        document.getElementById('revealedText').innerText = m.txt;
    }

    let poppedCount = 0;
    function checkFinish() {
        poppedCount++;
        if(poppedCount >= memories.length) {
            document.getElementById('finalBtn').style.display = 'inline-block';
        }
    }

    function showFinal() {
        document.getElementById('balloonArea').style.display = 'none';
        document.getElementById('finalArea').style.display = 'block';
    }

    function toBase64(file) {
        return new Promise((resolve) => {
            const reader = new FileReader();
            reader.onloadend = () => resolve(reader.result);
            reader.readAsDataURL(file);
        });
    }

    function popSound() {
        const audio = new Audio('https://www.soundjay.com/misc/sounds/balloon-pop-1.mp3');
        audio.play();
    }
</script>
</body>
</html>
