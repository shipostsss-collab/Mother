<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mother's Day Creator</title>
    <style>
        body { font-family: sans-serif; background: #fff0f3; text-align: center; padding: 20px; }
        .card { background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        h1 { color: #c9184a; }
        input, button { width: 90%; padding: 12px; margin: 10px 0; border-radius: 8px; border: 1px solid #ddd; }
        button { background: #ff85a1; color: white; font-weight: bold; cursor: pointer; border: none; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Mom's Surprise Creator</h1>
        <p>If you see this, the website is WORKING!</p>
        <input type="text" id="momName" placeholder="Enter Name (e.g. Queen)">
        <p>Upload Cover Photo:</p>
        <input type="file" id="pic" accept="image/*">
        <button onclick="alert('Ready to build!')">Next Step</button>
    </div>
</body>
</html>
